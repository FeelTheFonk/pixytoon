# PixyToon Server — Environment Configuration
# Copy this file to .env and customize as needed.
# All variables are prefixed with PIXYTOON_ and are optional.

# ── Network ──────────────────────────────────────────────────
# PIXYTOON_HOST=127.0.0.1
# PIXYTOON_PORT=9876

# ── Base Model ─────────────────────────────────────────────
# HuggingFace repo ID, local diffusers directory, or .safetensors/.ckpt file path
# PIXYTOON_DEFAULT_CHECKPOINT=Lykon/dreamshaper-8
# PIXYTOON_DEFAULT_CHECKPOINT=C:/models/mymodel.safetensors

# ── Hyper-SD (acceleration LoRA) ────────────────────────────
# PIXYTOON_HYPER_SD_REPO=ByteDance/Hyper-SD
# PIXYTOON_HYPER_SD_LORA_FILE=Hyper-SD15-8steps-CFG-lora.safetensors
# PIXYTOON_HYPER_SD_FUSE_SCALE=0.8

# ── Generation Defaults ─────────────────────────────────────
# PIXYTOON_DEFAULT_STEPS=8
# PIXYTOON_DEFAULT_CFG=5.0
# PIXYTOON_DEFAULT_WIDTH=512
# PIXYTOON_DEFAULT_HEIGHT=512
# PIXYTOON_DEFAULT_CLIP_SKIP=2

# ── Default Pixel Art LoRA ──────────────────────────────────
# "auto" = first .safetensors in loras_dir, "" = none
# PIXYTOON_DEFAULT_PIXEL_LORA=auto
# PIXYTOON_DEFAULT_PIXEL_LORA_WEIGHT=1.0

# ── Performance ──────────────────────────────────────────────
# PIXYTOON_ENABLE_TORCH_COMPILE=true
# PIXYTOON_COMPILE_MODE=default
# PIXYTOON_ENABLE_DEEPCACHE=true
# PIXYTOON_DEEPCACHE_INTERVAL=3
# PIXYTOON_DEEPCACHE_BRANCH=0
# PIXYTOON_ENABLE_ATTENTION_SLICING=true
# PIXYTOON_ENABLE_VAE_TILING=true
# PIXYTOON_ENABLE_WARMUP=true

# ── FreeU v2 ─────────────────────────────────────────────────
# PIXYTOON_ENABLE_FREEU=true
# PIXYTOON_FREEU_S1=0.9
# PIXYTOON_FREEU_S2=0.2
# PIXYTOON_FREEU_B1=1.5
# PIXYTOON_FREEU_B2=1.6

# ── Timeouts ─────────────────────────────────────────────────
# PIXYTOON_GENERATION_TIMEOUT=600.0

# ── Background Removal ───────────────────────────────────────
# PIXYTOON_REMBG_MODEL=u2net
# PIXYTOON_REMBG_ON_CPU=true
# Options: u2net (fast, ~3-4s CPU), birefnet-general (best edges, ~10s CPU), bria-rmbg (SOTA quality)

# ── Animation ────────────────────────────────────────────────
# PIXYTOON_DEFAULT_ANIM_FRAMES=8
# PIXYTOON_DEFAULT_ANIM_DURATION_MS=100
# PIXYTOON_DEFAULT_ANIM_DENOISE=0.30
# PIXYTOON_MAX_ANIMATION_FRAMES=120

# ── AnimateDiff ──────────────────────────────────────────────
# PIXYTOON_ANIMATEDIFF_MODEL=guoyww/animatediff-motion-adapter-v1-5-3
# PIXYTOON_ENABLE_FREEINIT=false
# PIXYTOON_FREEINIT_ITERATIONS=2

# ── Real-Time Paint Mode ───────────────────────────────────
# PIXYTOON_REALTIME_TIMEOUT=60.0
# PIXYTOON_REALTIME_DEFAULT_STEPS=4
# PIXYTOON_REALTIME_DEFAULT_CFG=2.5
# PIXYTOON_REALTIME_DEFAULT_DENOISE=0.5
