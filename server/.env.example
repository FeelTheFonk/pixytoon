# SDDj Server — Environment Configuration
# Copy this file to .env and customize as needed.
# All variables are prefixed with SDDJ_ and are optional.

# ── Offline Mode (100% local, no HuggingFace fetches) ────────
# Set by start.ps1 automatically. Uncomment to force in all contexts.
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1

# ── Network ──────────────────────────────────────────────────
# SDDJ_HOST=127.0.0.1
# SDDJ_PORT=9876

# ── Base Model ─────────────────────────────────────────────
# HuggingFace repo ID, local diffusers directory, or .safetensors/.ckpt file path
# Default: models/checkpoints/liberteRedmond_v10.safetensors
# SDDJ_DEFAULT_CHECKPOINT=models/checkpoints/liberteRedmond_v10.safetensors
# SDDJ_DEFAULT_CHECKPOINT=C:/models/mymodel.safetensors

# ── Hyper-SD (acceleration LoRA) ────────────────────────────
# SDDJ_HYPER_SD_REPO=ByteDance/Hyper-SD
# SDDJ_HYPER_SD_LORA_FILE=Hyper-SD15-8steps-CFG-lora.safetensors
# SDDJ_HYPER_SD_FUSE_SCALE=0.8

# ── Generation Defaults ─────────────────────────────────────
# SDDJ_DEFAULT_STEPS=8
# SDDJ_DEFAULT_CFG=5.0
# SDDJ_DEFAULT_WIDTH=512
# SDDJ_DEFAULT_HEIGHT=512
# SDDJ_DEFAULT_CLIP_SKIP=2

# ── Default Style LoRA ───────────────────────────────────────
# "auto" = first .safetensors in loras_dir, "" = none
# Accepts stem name (e.g. "pixelart_redmond") or full path
# SDDJ_DEFAULT_STYLE_LORA=auto
# SDDJ_DEFAULT_STYLE_LORA_WEIGHT=1.0

# ── Performance ──────────────────────────────────────────────
# SDDJ_ENABLE_TORCH_COMPILE=true
# SDDJ_COMPILE_MODE=default                          # default | max-autotune | reduce-overhead
# SDDJ_COMPILE_DYNAMIC=false                         # true only when DeepCache disabled (incompatible)
# SDDJ_ENABLE_DEEPCACHE=true
# SDDJ_DEEPCACHE_INTERVAL=3
# SDDJ_DEEPCACHE_BRANCH=0
# SDDJ_ENABLE_ATTENTION_SLICING=true
# SDDJ_ENABLE_VAE_TILING=true
# SDDJ_ENABLE_WARMUP=true
# SDDJ_ENABLE_TF32=true                              # Ampere+ free ~15-30% speedup
# SDDJ_ENABLE_LORA_HOTSWAP=true                      # Avoids torch.compile recompilation on LoRA switch
# SDDJ_MAX_LORA_RANK=128                              # Must be >= rank of all LoRA adapters used
# SDDJ_ENABLE_CPU_OFFLOAD=false                       # Mutually exclusive with DeepCache + torch.compile
# SDDJ_VRAM_MIN_FREE_MB=512                           # VRAM budget guard for lazy-loads

# ── FreeU v2 ─────────────────────────────────────────────────
# SDDJ_ENABLE_FREEU=true
# SDDJ_FREEU_S1=0.9
# SDDJ_FREEU_S2=0.2
# SDDJ_FREEU_B1=1.5
# SDDJ_FREEU_B2=1.6

# ── ControlNet QR Code Monster ───────────────────────────────
# SDDJ_QR_CONTROLNET_CONDITIONING_SCALE=1.5
# SDDJ_QR_CONTROL_GUIDANCE_START=0.0
# SDDJ_QR_CONTROL_GUIDANCE_END=0.8
# SDDJ_QR_DEFAULT_STEPS=20

# ── Timeouts ─────────────────────────────────────────────────
# SDDJ_GENERATION_TIMEOUT=600.0

# ── Background Removal ───────────────────────────────────────
# SDDJ_REMBG_MODEL=u2net
# SDDJ_REMBG_ON_CPU=true
# Options: u2net (fast, ~3-4s CPU), birefnet-general (best edges, ~10s CPU), bria-rmbg (SOTA quality)

# ── Animation ────────────────────────────────────────────────
# SDDJ_MAX_ANIMATION_FRAMES=256

# ── AnimateDiff ──────────────────────────────────────────────
# Default: ByteDance/AnimateDiff-Lightning (10× faster, distilled)
# Standard (non-Lightning) adapter:
# SDDJ_ANIMATEDIFF_MODEL=guoyww/animatediff-motion-adapter-v1-5-3
#
# Lightning-specific settings (active by default):
# SDDJ_ANIMATEDIFF_LIGHTNING_STEPS=4                  # Must match checkpoint: 2, 4, or 8
# SDDJ_ANIMATEDIFF_LIGHTNING_CFG=2.0                  # 2.0 preserves negative prompts; 1.0 = neg ignored
# SDDJ_ANIMATEDIFF_MOTION_LORA_STRENGTH=0.75          # Motion LoRA strength (0.7-0.8 avoids watermarks)
# SDDJ_ANIMATEDIFF_LIGHTNING_FREEU=true                # FreeU for Lightning (set false if quality issues)
#
# SDDJ_ENABLE_FREEINIT=false
# SDDJ_FREEINIT_ITERATIONS=2

# ── FreeNoise (long sequences, non-Lightning only) ──────────
# Sliding window + noise rescheduling for temporal coherence on long animations.
# SDDJ_ANIMATEDIFF_CONTEXT_LENGTH=16                  # Window size (8-32 frames)
# SDDJ_ANIMATEDIFF_CONTEXT_STRIDE=4                   # Window stride (1-16, lower = better coherence, slower)
# SDDJ_ANIMATEDIFF_SPLIT_INFERENCE=true                # Auto-enable SplitInference for long sequences
# SDDJ_ANIMATEDIFF_SPATIAL_SPLIT_SIZE=256              # Spatial split tile size (64-512)
# SDDJ_ANIMATEDIFF_TEMPORAL_SPLIT_SIZE=16              # Temporal split chunk size (4-32)
# SDDJ_ANIMATEDIFF_MAX_FRAMES_LIGHTNING=32             # Hard cap for Lightning (FreeNoise incompatible)

# ── Audio Reactivity ─────────────────────────────────────────
# SDDJ_AUDIO_CACHE_DIR=                               # empty = system temp dir
# SDDJ_AUDIO_MAX_FILE_SIZE_MB=500
# SDDJ_AUDIO_MAX_FRAMES=10800                         # ~7.5 min at 24fps
# SDDJ_AUDIO_DEFAULT_ATTACK=2
# SDDJ_AUDIO_DEFAULT_RELEASE=8
# SDDJ_STEM_MODEL=htdemucs
# SDDJ_STEM_DEVICE=cpu                                # always CPU — keep GPU free for diffusion

# ── Audio DSP Precision ──────────────────────────────────────
# SDDJ_AUDIO_SAMPLE_RATE=44100                        # 22050-96000
# SDDJ_AUDIO_HOP_LENGTH=256                           # 64-1024
# SDDJ_AUDIO_N_FFT=4096                               # 512-8192
# SDDJ_AUDIO_N_MELS=256                               # 64-512
# SDDJ_AUDIO_PERCEPTUAL_WEIGHTING=true                # K-weighting pre-filter (ITU-R BS.1770)
# SDDJ_AUDIO_SMOOTHING_MODE=ema                       # ema | savgol
# SDDJ_AUDIO_BEAT_BACKEND=auto                        # auto | librosa | madmom
# SDDJ_AUDIO_SUPERFLUX_LAG=2                          # 1-5
# SDDJ_AUDIO_SUPERFLUX_MAX_SIZE=3                     # 1-7

# ── Temporal Coherence ────────────────────────────────────
# SDDJ_DISTILLED_STEP_SCALE_CAP=2                     # Max step multiplier for distilled models (1-10)
# SDDJ_COLOR_COHERENCE_STRENGTH=0.5                   # LAB color matching between frames (0=off, 0.3-0.7 recommended)
# SDDJ_AUTO_NOISE_COUPLING=true                       # Auto noise injection inversely proportional to denoise
# SDDJ_OPTICAL_FLOW_BLEND=0.0                         # Flow-warped temporal blend (0=off, 0.1-0.3 recommended)

# ── Video Export ──────────────────────────────────────────────
# SDDJ_FFMPEG_PATH=                                   # empty = auto-detect via shutil.which("ffmpeg")
# SDDJ_AUDIO_CACHE_TTL_HOURS=24                       # 1h-7d
