# ─────────────────────────────────────────────────────────────
# SDDj Environment Configuration
# Copy to .env and adjust as needed.  All values shown are defaults.
# See docs/REFERENCE.md § Configuration for the full reference.
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
SDDJ_HOST=127.0.0.1
SDDJ_PORT=9876

# ── Model Paths ──────────────────────────────────────────────
# SDDJ_MODELS_DIR=models
# SDDJ_CHECKPOINTS_DIR=models/checkpoints
# SDDJ_LORAS_DIR=models/loras
# SDDJ_EMBEDDINGS_DIR=models/embeddings

# ── Performance ───────────────────────────────────────────────
SDDJ_ENABLE_DEEPCACHE=true
SDDJ_DEEPCACHE_INTERVAL=3
SDDJ_ENABLE_TORCH_COMPILE=true
SDDJ_COMPILE_DYNAMIC=false
SDDJ_ENABLE_TF32=true

# ── LoRA ──────────────────────────────────────────────────────
SDDJ_ENABLE_LORA_HOTSWAP=true
# SDDJ_MAX_LORA_RANK=128

# ── FreeU v2 ─────────────────────────────────────────────────
SDDJ_ENABLE_FREEU=true
SDDJ_FREEU_B1=1.5
SDDJ_FREEU_B2=1.6
SDDJ_FREEU_S1=0.9
SDDJ_FREEU_S2=0.2

# ── AnimateDiff ──────────────────────────────────────────────
# SDDJ_ANIMATEDIFF_MODEL=guoyww/animatediff-motion-adapter-v1-5-3
# SDDJ_ANIMATEDIFF_LIGHTNING_STEPS=4
# SDDJ_ANIMATEDIFF_LIGHTNING_CFG=2.0
# SDDJ_ANIMATEDIFF_MOTION_LORA_STRENGTH=0.8
# SDDJ_ANIMATEDIFF_LIGHTNING_FREEU=false

# ── VRAM ──────────────────────────────────────────────────────
SDDJ_VRAM_MIN_FREE_MB=512
# SDDJ_ENABLE_CPU_OFFLOAD=false

# ── Quantization ─────────────────────────────────────────────
# UNet quantization planned but not yet implemented
# SDDJ_QUANTIZE_UNET=none

# ── Audio DSP ────────────────────────────────────────────────
SDDJ_AUDIO_SAMPLE_RATE=48000
SDDJ_AUDIO_HOP_LENGTH=512
SDDJ_AUDIO_N_FFT=8192
SDDJ_AUDIO_N_MELS=512
SDDJ_AUDIO_PERCEPTUAL_WEIGHTING=true
SDDJ_AUDIO_SMOOTHING_MODE=ema
# SDDJ_AUDIO_BEAT_BACKEND=librosa
# SDDJ_AUDIO_SUPERFLUX_LAG=2
# SDDJ_AUDIO_SUPERFLUX_MAX_SIZE=3

# ── Audio Cache ──────────────────────────────────────────────
SDDJ_AUDIO_CACHE_TTL_HOURS=24

# ── Video Export ─────────────────────────────────────────────
# SDDJ_FFMPEG_PATH=  (auto-detect)
